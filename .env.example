# ---- Embeddings (local, no API key needed) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- LLM backend: "ollama" (offline) or "groq" (cloud free tier) ----
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq (used when LLM_PROVIDER=groq) — get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ---- Storage (defaults are fine) ----
# VAULT_DIR=./vault
# INDEX_DIR=./.index

# ---- Retrieval / chunking ----
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5

# ---- Web UI ----
FLASK_HOST=127.0.0.1
FLASK_PORT=5566
